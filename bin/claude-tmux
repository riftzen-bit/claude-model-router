#!/bin/bash
# claude-tmux: Launch claude inside tmux for /design (Gemini worker) support
# Install to ~/.local/bin/claude-tmux and alias claude='claude-tmux'
# Usage: claude-tmux [any claude args...]

SESSION_NAME="${CLAUDE_TMUX_SESSION:-Work}"
CLAUDE_BIN="$(command -v claude)"

if [ -z "$CLAUDE_BIN" ]; then
  echo "Error: claude not found in PATH"
  exit 1
fi

# Already inside tmux? Just run claude directly
if [ -n "$TMUX" ]; then
  exec "$CLAUDE_BIN" --dangerously-skip-permissions "$@"
fi

# Not in tmux — create detached session/window, then attach
# Use printf %q to safely quote arguments
QUOTED_ARGS=""
for arg in "$@"; do
  QUOTED_ARGS="$QUOTED_ARGS $(printf '%q' "$arg")"
done

CMD="$CLAUDE_BIN --dangerously-skip-permissions $QUOTED_ARGS; exec bash"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  # Session exists — add a new window, then attach
  tmux new-window -t "$SESSION_NAME" -n claude "$CMD"
  exec tmux attach-session -t "$SESSION_NAME"
else
  # No session — create detached, then attach (2-step avoids silent failure)
  tmux new-session -d -s "$SESSION_NAME" -n claude "$CMD"
  exec tmux attach-session -t "$SESSION_NAME"
fi
